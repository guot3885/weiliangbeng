{
  "name": "medical-pump-calculator",
  "displayName": "医学微量泵计算工具",
  "version": "1.0.0",
  "description": "用于快速计算微量泵的泵入速度和溶液浓度的医疗工具",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "cordova build android --release",
    "debug": "cordova build android",
    "run": "cordova run android",
    "prepare": "cordova prepare",
    "clean": "cordova clean"
  },
  "keywords": [
    "medical",
    "calculator",
    "pump",
    "healthcare",
    "cordova",
    "android"
  ],
  "author": "Medical Tool Team",
  "license": "MIT",
  "cordova": {
    "platforms": [
      "android"
    ],
    "plugins": [
      "cordova-plugin-whitelist",
      "cordova-plugin-statusbar",
      "cordova-plugin-splashscreen",
      "cordova-plugin-file",
      "cordova-plugin-file-transfer",
      "cordova-plugin-android-permissions",
      "cordova-plugin-sharing",
      "cordova-plugin-dialogs"
    ]
  },
  "dependencies": {
    "cordova-android": "^10.1.2",
    "cordova-plugin-android-permissions": "^1.1.5",
    "cordova-plugin-dialogs": "^2.0.2",
    "cordova-plugin-file": "^7.0.0",
    "cordova-plugin-file-transfer": "^1.7.1",
    "cordova-plugin-sharing": "^0.1.4",
    "cordova-plugin-splashscreen": "^6.0.1",
    "cordova-plugin-statusbar": "^3.0.0",
    "cordova-plugin-whitelist": "^1.3.5"
  },
  "devDependencies": {
    "cordova-cli": "^11.0.0"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}